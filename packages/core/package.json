{
  "name": "@choirmaster/core",
  "version": "0.3.2",
  "description": "ChoirMaster runtime (internal). Bundled into the published `choirmaster` package; do not depend on this directly.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomiwaajayi/choirmaster.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
