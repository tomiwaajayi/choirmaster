{
  "name": "@choirmaster/core",
  "version": "0.0.0",
  "description": "ChoirMaster runtime: state machine, gate runner, worktree management, agent + sandbox interfaces",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomiwaajayi/choirmaster.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
