{
  "name": "choirmaster",
  "version": "0.3.4",
  "description": "Local orchestrator for AI coding agents. Drive multi-step refactors with scoped tasks, isolated worktrees, deterministic gates, and resumable runs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "choirmaster": "dist/cli.js",
    "cm": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"import('node:fs').then(m=>m.chmodSync('dist/cli.js',0o755))\"",
    "prepack": "node scripts/copy-package-files.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist README.md LICENSE *.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomiwaajayi/choirmaster.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "claude-code",
    "codex",
    "orchestrator",
    "agentic-coding",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@choirmaster/agent-claude": "workspace:*",
    "@choirmaster/core": "workspace:*",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
