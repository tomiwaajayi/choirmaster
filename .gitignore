# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
*.tsbuildinfo

# Synced into packages/cli/ at prepack time from the repo root; tracked
# only at the root to prevent drift between root and published copies.
packages/cli/README.md
packages/cli/LICENSE

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Test artifacts
coverage/
.vitest/

# Runtime artifacts (per-project, see template/)
.choirmaster/runs/

# Generated task files (planner output). The markdown plan is the input
# of record; the .tasks.json next to it is regenerated each run. Force
# with `git add -f` to pin a specific generated tasks file.
.choirmaster/plans/*.tasks.json

# Env
.env
.env.*
!.env.example
